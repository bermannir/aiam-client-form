# Server
PORT=3001

# Google Sheets — same spreadsheet as AIAM agent (or create a new one)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=../AIAM agent/credentials/google-service-account.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_QUESTIONNAIRE_TAB=שאלונים

# Email (Gmail — use App Password, not your regular password)
# Create App Password: Google Account → Security → 2-Step Verification → App passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM="AI-AM Solutions <your_gmail@gmail.com>"
NOTIFICATION_EMAIL=bermannir@gmail.com
